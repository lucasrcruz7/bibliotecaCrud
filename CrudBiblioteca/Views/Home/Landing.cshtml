@{
    ViewData["Title"] = "Bem-vindo";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Biblioteca — Bem-vindo</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
        }
        .hero-icon { font-size: 5rem; }
        .card-feature {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            transition: transform 0.2s;
        }
        .card-feature:hover { transform: translateY(-4px); }
        .btn-login  { background: #e94560; border: none; color: white; }
        .btn-login:hover  { background: #c73652; color: white; }
        .btn-cadastro { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; }
        .btn-cadastro:hover { background: rgba(255,255,255,0.25); color: white; }
    </style>
</head>
<body>

    <div class="container py-5">

        @* Hero *@
        <div class="text-center mb-5">
            <div class="hero-icon mb-3">📚</div>
            <h1 class="display-5 fw-bold">Sistema de Biblioteca</h1>
            <p class="lead text-white-50 mb-4">
                Gerencie livros, usuários e empréstimos de forma simples e organizada.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Usuarios" asp-action="Login"
                   class="btn btn-login btn-lg px-5">Entrar</a>
                <a asp-controller="Usuarios" asp-action="Create"
                   class="btn btn-cadastro btn-lg px-5">Criar conta</a>
            </div>
        </div>

        @* Cards de funcionalidades *@
        <div class="row g-4 justify-content-center mb-5">
            <div class="col-md-4">
                <div class="card-feature p-4 text-center h-100">
                    <div class="fs-1 mb-3">📖</div>
                    <h5 class="fw-bold">Acervo de Livros</h5>
                    <p class="text-white-50 small mb-0">
                        Cadastre e gerencie o acervo com controle de estoque,
                        categorias e faixa etária.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-feature p-4 text-center h-100">
                    <div class="fs-1 mb-3">👤</div>
                    <h5 class="fw-bold">Gestão de Usuários</h5>
                    <p class="text-white-50 small mb-0">
                        Controle de cadastro, status ativo/inativo
                        e histórico completo de empréstimos por pessoa.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-feature p-4 text-center h-100">
                    <div class="fs-1 mb-3">🔄</div>
                    <h5 class="fw-bold">Controle de Empréstimos</h5>
                    <p class="text-white-50 small mb-0">
                        Registre empréstimos e devoluções com cálculo
                        automático de multas por atraso.
                    </p>
                </div>
            </div>
        </div>

        <p class="text-center text-white-50 small">
            Faça login ou crie sua conta para acessar o sistema.
        </p>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
