@model CrudBiblioteca.Models.Usuario

@{
    ViewData["Title"] = "Novo Usuário";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">👤 Cadastrar Usuário</h4>
            </div>
            <div class="card-body">

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="NomeCompleto" class="form-label fw-semibold">Nome Completo</label>
                        <input asp-for="NomeCompleto" class="form-control" placeholder="Ex: João da Silva" />
                        <span asp-validation-for="NomeCompleto" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DataNascimento" class="form-label fw-semibold">Data de Nascimento</label>
                        <input asp-for="DataNascimento" class="form-control" type="date"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DataNascimento" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">E-mail</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="Ex: joao@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Senha" class="form-label fw-semibold">Senha</label>
                        <input asp-for="Senha" class="form-control" type="password" />
                        <span asp-validation-for="Senha" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold">Status</label>
                        <select asp-for="Status" class="form-select"
                                asp-items="Html.GetEnumSelectList<CrudBiblioteca.Models.StatusUsuario>()">
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Cadastrar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
