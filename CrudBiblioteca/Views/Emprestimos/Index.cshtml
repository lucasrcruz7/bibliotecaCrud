@model IEnumerable<CrudBiblioteca.Models.Emprestimo>

@{
    ViewData["Title"] = "Empréstimos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">📚 Empréstimos</h2>
    <a asp-action="Create" class="btn btn-primary">+ Novo Empréstimo</a>
</div>

@* Mensagens de feedback *@
@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Filtros *@
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Filtrar por Usuário</label>
                <select name="usuarioId" class="form-select">
                    <option value="">— Todos —</option>
                    @foreach (var item in (SelectList)ViewBag.Usuarios)
                    {
                        <option value="@item.Value"
                                selected="@(item.Value == ViewBag.UsuarioFiltro?.ToString())">
                            @item.Text
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Filtrar por Status</label>
                <select name="status" class="form-select">
                    <option value="">— Todos —</option>
                    <option value="1" selected="@(ViewBag.StatusFiltro?.ToString() == "1")">Emprestado</option>
                    <option value="2" selected="@(ViewBag.StatusFiltro?.ToString() == "2")">Devolvido</option>
                    <option value="3" selected="@(ViewBag.StatusFiltro?.ToString() == "3")">Atrasado</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpar</a>
            </div>
        </form>
    </div>
</div>

@* Tabela *@
@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum empréstimo encontrado.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Usuário</th>
                    <th>Livro</th>
                    <th>Data Empréstimo</th>
                    <th>Prev. Devolução</th>
                    <th>Devolução Real</th>
                    <th>Multa</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Id</td>
                        <td>@e.Usuario.NomeCompleto</td>
                        <td>@e.Livro.NomeLivro</td>
                        <td>@e.DataEmprestimo.ToString("dd/MM/yyyy")</td>
                        <td>@e.DataPrevistaDevolucao.ToString("dd/MM/yyyy")</td>
                        <td>
                            @(e.DataRealDevolucao.HasValue
                                ? e.DataRealDevolucao.Value.ToString("dd/MM/yyyy")
                                : "—")
                        </td>
                        <td>
                            @if (e.Multa > 0)
                            {
                                <span class="text-danger fw-bold">R$ @e.Multa.ToString("F2")</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @switch (e.Status)
                            {
                                case CrudBiblioteca.Models.StatusEmprestimo.Emprestado:
                                    <span class="badge bg-primary">Emprestado</span>
                                    break;
                                case CrudBiblioteca.Models.StatusEmprestimo.Devolvido:
                                    <span class="badge bg-success">Devolvido</span>
                                    break;
                                case CrudBiblioteca.Models.StatusEmprestimo.Atrasado:
                                    <span class="badge bg-danger">Atrasado</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@e.Id"
                               class="btn btn-sm btn-outline-info">Detalhes</a>

                            @if (e.Status != CrudBiblioteca.Models.StatusEmprestimo.Devolvido)
                            {
                                <a asp-action="Devolver" asp-route-id="@e.Id"
                                   class="btn btn-sm btn-outline-warning ms-1">Devolver</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
